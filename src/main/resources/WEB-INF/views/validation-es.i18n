acme.validation.header.message = El campo no puede estar vacío y debe tener el tamaño correcto.
acme.validation.text.message = El texto no puede estar vacío y debe tener el tamaño correcto.

acme.validation.ticker.message = Formato de ticker incorrecto. Debe ser, por ejemplo, AA11-ABCDE.
acme.validation.audit-report.invalid-period = La fecha de inicio debe ser estrictamente anterior a la de fin.
acme.validation.audit-report.not-future = La fecha de inicio debe ser en el futuro.
acme.validation.audit-report.duplicated-ticker.message = Ya existe un Informe de Auditoría con este Ticker.
