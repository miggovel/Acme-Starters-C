acme.validation.campaign.duplicated-ticker.message = The ticker is duplicated
acme.validation.campaign.interval.message = End moment must be after start moment
acme.validation.campaign.timeInterval.message = End moment must be after start moment
acme.validation.campaign.publish.minimum-milestones.message = You must define at least one milestone before publishing
acme.validation.campaign.publish.interval.message = Start and end moments must define a future interval when publishing


acme.validation.strategy.duplicated-ticker.message = The ticker is duplicated
acme.validation.strategy.interval.message = End moment must be after start moment
acme.validation.strategy.publish.minimum-tactics.message = You must define at least one tactic before publishing
acme.validation.strategy.publish.expected-percentage.message = The total expected percentage must be between 0 and 100
acme.validation.strategy.publish.interval.message = Start and end moments must define a future interval when publishing
